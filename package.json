{
  "name": "lastfm-readme",
  "version": "1.7.0",
  "description": "GitHub Action to dynamically update your GitHub README with Last.fm metrics",
  "keywords": [
    "lastfm",
    "actions",
    "readme"
  ],
  "homepage": "https://github.com/dxnter/lastfm-readme#readme",
  "bugs": {
    "url": "https://github.com/dxnter/lastfm-readme/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxnter/lastfm-readme.git"
  },
  "license": "MIT",
  "author": "Danny Foster <danny@foster.sh>",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "dev": "tsx src/development.ts",
    "format": "prettier --write --cache --cache-location=.prettier-cache \"**/*.{ts,js,md,json,yml}\"",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "semantic-release": "semantic-release",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "types": "tsc --project tsconfig.eslint.json --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/core": "^7.0.6",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "date-fns": "^4.1.0",
    "lastfm-typed": "^2.1.0",
    "ramda": "^0.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.6.0",
    "@types/ramda": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-gha": "^2.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "semantic-release": "^25.0.3",
    "semantic-release-major-tag": "^0.3.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24.10.0",
    "npm": "please-use-pnpm",
    "pnpm": ">=10.0.0",
    "yarn": "please-use-pnpm"
  }
}
